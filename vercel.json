{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
